    "check:watch": "tsc --watch",
    "lint": "eslint",
    "lint:watch": "node --watch-path=./src ./node_modules/eslint/bin/eslint.js",
    "test": "node --test src/**/*.test.ts",
    "build": "vite build",
    "pre-commit": "pnpm check && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
