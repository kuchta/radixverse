{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "start",
			// "isBackground": true, // Don't use this if you want to debug the task
			// "problemMatcher": []
		},
		{
			"type": "npm",
			"script": "preview",
			"problemMatcher": [],
			"isBackground": true,
		},
		{
			"type": "npm",
			"script": "check",
			"problemMatcher": ["$tsc"]
		},
		{
			"type": "npm",
			"script": "check:watch",
			"problemMatcher": ["$tsc"],
			"isBackground": true,
		},
		{
			"type": "npm",
			"script": "lint",
			"problemMatcher": ["$eslint-stylish"]
		},
		{
			"type": "npm",
			"script": "lint:watch",
			"problemMatcher": ["$eslint-stylish"],
			"isBackground": true,
		},
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": ["$eslint-stylish"],
			"isBackground": true,
		},
		{
			"type": "npm",
			"script": "build",
			"problemMatcher": ["$tsc"],
			"group": "build",
		},
		{
			"type": "npm",
			"script": "pre-commit",
			"problemMatcher": []
		},
		{
			"type": "shell",
			"label": "stop",
			"command": "echo ${input:terminate}",
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "terminate",
			"type": "command",
			"command": "workbench.action.tasks.terminate",
			"args": "start"
		}
	]
}
