{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "start",
			"type": "npm",
			"script": "start",
			// "isBackground": true, // Don't use this if you want to debug the task
			// "problemMatcher": []
		},
		{
			"type": "npm",
			"script": "preview",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "check",
			"problemMatcher": ["$tsc"]
		},
		{
			"type": "npm",
			"script": "lint",
			"problemMatcher": ["$eslint-compact"]
		},
		{
			"type": "npm",
			"script": "build",
			"group": "build",
			"problemMatcher": ["$tsc"]
		},
		{
			"type": "npm",
			"script": "pre-commit",
			"problemMatcher": []
		},
		{
			"label": "stop",
			"command": "echo ${input:terminate}",
			"type": "shell",
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "terminate",
			"type": "command",
			"command": "workbench.action.tasks.terminate",
			"args": "start"
		}
	]
}
